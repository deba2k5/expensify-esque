# Environment Variables for Frontend

# Backend API URL (point to your Vercel backend)
VITE_MONGODB_API_URL=https://backend.vercel.app/api

# WebSocket URL (same as backend)
VITE_WS_URL=https://backend.vercel.app

# Google Drive Upload URL (Apps Script deployment)
VITE_GOOGLE_DRIVE_UPLOAD_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Admin emails (comma-separated)
VITE_ADMIN_EMAILS=admin@sinhas.ch

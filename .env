# ---- Employee Tracking System ----
# Copy these into your Lovable project .env (do NOT commit real values).
# The .env file is auto-managed; add VITE_* variables in Project Settings → Variables
# if your sandbox does not let you edit .env directly.

# Base URL of your MongoDB-backed REST API (see BACKEND.md for required endpoints).
# Example: https://your-api.onrender.com/api
# If left empty the app falls back to a local-storage mock so the UI still works.
# Uncomment for LOCAL testing:
# VITE_MONGODB_API_URL=http://192.168.1.34:5000/api
# Uncomment for PRODUCTION (Vercel deployed):
VITE_MONGODB_API_URL=https://sinhasbackend1.vercel.app/api

# Google Drive upload endpoint OR shared folder URL for document uploads.
# Easiest option: a Google Apps Script Web App that accepts multipart POST and
# returns { url: "https://drive.google.com/..." }.  See BACKEND.md.
VITE_GOOGLE_DRIVE_UPLOAD_URL=https://drive.google.com/drive/folders/1i5eJ2S3LVEsnEYI8gpljk-E0eoq6rCSb

# Optional: hard-coded admin emails (comma-separated). Defaults to admin@sinhas.ch.
VITE_ADMIN_EMAILS=admin@sinhas.ch,manager@sinhas.ch

# WebSocket Backend (for real-time updates)
# Uncomment for LOCAL testing:
# VITE_WS_URL=http://192.168.1.34:5000
# Uncomment for PRODUCTION (Vercel deployed):
VITE_WS_URL=https://sinhasbackend1.vercel.app

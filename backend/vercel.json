{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "GOOGLE_DRIVE_FOLDER_ID": "@google_drive_folder_id",
    "FLASK_ENV": "production",
    "ADMIN_EMAILS": "@admin_emails"
  },
  "buildCommand": "pip install -r requirements.txt",
  "framework": "flask"
}

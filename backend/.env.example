# Environment Variables for Backend

# MongoDB Atlas Connection String
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/workforce-vision

# Google Drive Folder ID for uploads
# Get from: https://drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=1i5eJ2S3LVEsnEYI8gpljk-E0eoq6rCSb

# Admin email addresses (comma-separated)
ADMIN_EMAILS=admin@sinhas.ch

# Flask Environment (production or development)
FLASK_ENV=production
